# ── Supabase (REQUIRED — the app won't start without these) ──────────────────
# Get them from your Supabase project: Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...            # "anon public" key
SUPABASE_SERVICE_ROLE_KEY=eyJ...                # "service_role" key (server only — keep secret)

# ── AI provider (Anthropic — required for the agent / native tool calling) ────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# ── Cookie signing (run: openssl rand -base64 32) ─────────────────────────────
COOKIE_SECRET=replace-with-32-byte-random-string
